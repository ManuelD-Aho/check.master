{
    "name": "checkmaster/ufhb",
    "description": "CheckMaster - Système de gestion académique pour mémoires de Master UFHB",
    "version": "1.0.0",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "CheckMaster Team",
            "email": "dev@checkmaster.ci"
        }
    ],
    "require": {
        "php": "^8.0",
        "hashids/hashids": "^4.0",
        "symfony/validator": "^5.4",
        "symfony/http-foundation": "^5.4",
        "symfony/cache": "^5.4",
        "mpdf/mpdf": "^8.0",
        "tecnickcom/tcpdf": "^6.6",
        "phpoffice/phpspreadsheet": "^1.18",
        "phpmailer/phpmailer": "^6.9",
        "monolog/monolog": "^2.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.48",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Src\\": "src/",
            "Database\\": "database/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse -c phpstan.neon",
        "fix": "php-cs-fixer fix",
        "check": [
            "@stan",
            "@test"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
